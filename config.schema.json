{
  "pluginAlias": "OctoPrintMatterStatus",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "headerDisplay": "Expose your OctoPrint print status as Matter sensors (occupancy/contact). An OctoPrint API key with STATUS permission is required per printer.",
  "footerDisplay": "Enable Matter on the bridge (or child bridge), then pair the Matter QR code in Apple Home, Google Home, Alexa, or another controller.",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform name",
        "type": "string",
        "default": "OctoPrint Matter Status",
        "required": true
      },
      "printers": {
        "title": "Printers",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "title": "Identifier",
              "description": "Unique stable identifier (e.g. mk3s). Do not change after pairing.",
              "type": "string",
              "required": true,
              "pattern": "^[A-Za-z0-9._-]+$"
            },
            "sensorName": {
              "title": "Sensor name",
              "description": "Name shown in Apple Home / Matter (e.g. Prusa MK3S Printing).",
              "type": "string",
              "required": true
            },
            "octoprintUrl": {
              "title": "OctoPrint URL",
              "description": "Full URL, e.g. http://octopi.local",
              "type": "string",
              "required": true,
              "format": "uri"
            },
            "apiKey": {
              "title": "API key",
              "description": "User or application API key with STATUS permission.",
              "type": "string",
              "required": true
            },
            "sensorType": {
              "title": "Sensor type",
              "type": "string",
              "default": "occupancy",
              "oneOf": [
                { "title": "Occupancy / Motion", "enum": ["occupancy"] },
                { "title": "Contact", "enum": ["contact"] }
              ]
            },
            "enabled": {
              "title": "Enabled",
              "type": "boolean",
              "default": true
            },
            "pollIntervalSeconds": {
              "title": "Polling interval (s)",
              "type": "integer",
              "default": 10,
              "minimum": 2,
              "maximum": 3600
            },
            "invertState": {
              "title": "Invert state",
              "description": "Inverts detection (printing = inactive).",
              "type": "boolean",
              "default": false
            },
            "pausedAsActive": {
              "title": "Treat paused as active",
              "description": "When enabled, a paused print remains active/occupied instead of becoming inactive.",
              "type": "boolean",
              "default": false
            }
          }
        }
      },
      "debug": {
        "title": "Debug logging",
        "type": "boolean",
        "default": false
      }
    }
  }
}
