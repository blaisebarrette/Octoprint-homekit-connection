{
  "pluginAlias": "OctoPrintMatterStatus",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "headerDisplay": "Expose l'état d'impression de vos imprimantes OctoPrint comme capteurs Matter (occupancy/contact). Une clé API OctoPrint avec la permission STATUS est requise par imprimante.",
  "footerDisplay": "Activez Matter sur le bridge (ou child bridge) puis appairez le code QR Matter dans Apple Home, Google Home, Alexa ou autre.",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Nom de la plateforme",
        "type": "string",
        "default": "OctoPrint Matter Status",
        "required": true
      },
      "printers": {
        "title": "Imprimantes",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "title": "Identifiant",
              "description": "Identifiant unique et stable (ex: mk3s). Ne pas changer après l'appairage.",
              "type": "string",
              "required": true,
              "pattern": "^[A-Za-z0-9._-]+$"
            },
            "sensorName": {
              "title": "Nom du capteur",
              "description": "Nom affiché dans Apple Home / Matter (ex: Prusa MK3S Printing).",
              "type": "string",
              "required": true
            },
            "octoprintUrl": {
              "title": "URL OctoPrint",
              "description": "URL complète, ex: http://octopi.local",
              "type": "string",
              "required": true,
              "format": "uri"
            },
            "apiKey": {
              "title": "Clé API",
              "description": "Clé API utilisateur ou application avec permission STATUS.",
              "type": "string",
              "required": true
            },
            "sensorType": {
              "title": "Type de capteur",
              "type": "string",
              "default": "occupancy",
              "oneOf": [
                { "title": "Occupancy / Motion", "enum": ["occupancy"] },
                { "title": "Contact", "enum": ["contact"] }
              ]
            },
            "enabled": {
              "title": "Activée",
              "type": "boolean",
              "default": true
            },
            "pollIntervalSeconds": {
              "title": "Intervalle de polling (s)",
              "type": "integer",
              "default": 10,
              "minimum": 2,
              "maximum": 3600
            },
            "invertState": {
              "title": "Inverser l'état",
              "description": "Inverse la détection (impression = inactif).",
              "type": "boolean",
              "default": false
            }
          }
        }
      },
      "debug": {
        "title": "Journaux de débogage",
        "type": "boolean",
        "default": false
      }
    }
  }
}
